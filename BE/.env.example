# Copy this file to .env and replace placeholder values before running Docker Compose.
# Do not commit your real .env file.

# Database
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=evidence_pilot
MYSQL_USER=ep_user
MYSQL_PASSWORD=change-me-db-password
DB_PORT_HOST=3306

# Backend
BACKEND_PORT_HOST=8080
SERVER_PORT=8080
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION_MS=86400000

# Default admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Email verification
# Use the frontend verification page URL. The backend appends ?token=...
EMAIL_VERIFICATION_URL=http://localhost:5173/verify-email
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Gmail SMTP
# MAIL_PASSWORD must be a Google App Password, not your normal Gmail password.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_google_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# AI worker
AI_MODEL_BASE_URL=
AI_MODEL_API_KEY=
AI_MODEL_READ_TIMEOUT_SECONDS=600

# Qdrant
QDRANT_PORT_HOST=6333

# Uploads
APP_UPLOAD_DIR=/app/uploads
