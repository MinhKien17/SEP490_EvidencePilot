# Database
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=evidence_pilot
MYSQL_USER=evidencepilot
MYSQL_PASSWORD=
DB_PORT_HOST=3307

# Seed accounts (leave a pair blank to skip that account)
ADMIN_EMAIL=
ADMIN_PASSWORD=
STUDENT_EMAIL=
STUDENT_PASSWORD=
INSTRUCTOR_EMAIL=
INSTRUCTOR_PASSWORD=

# Backend auth
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# AI worker
AI_MODEL_BASE_URL=
AI_MODEL_API_KEY=
AI_MODEL_READ_TIMEOUT_SECONDS=600
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_GENERATION_MODEL=evidencopilot:latest

# Qdrant
QDRANT_URL=http://vector-db:6333
QDRANT_API_KEY=
QDRANT_PORT_HOST=6333

# MinIO
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=evidence-pilot-bucket

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=

# Email verification
EMAIL_VERIFICATION_URL=
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
MAIL_HOST=
